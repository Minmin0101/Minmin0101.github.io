.fluid-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}


.scroll-down {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  animation: bounce 2s infinite;
}

.arrow {
  width: 2rem;
  height: 2rem;
  color: #fff;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  40% {
    transform: translateX(-50%) translateY(-20px);
  }
  60% {
    transform: translateX(-50%) translateY(-10px);
  }
}

/* 波浪背景样式 - 适配移动端 */
.fluid-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;   /* 移动端视口宽度 */
  height: 100vh;  /* 移动端视口高度 */
  z-index: -9999; /* 最底层，不遮挡内容 */
  background: #0f172a; /* 深色底色，搭配波浪更美观 */
  pointer-events: none; /* 不影响页面点击 */
  touch-action: none;   /* 移动端触摸优化 */
}

/* 移动端适配：防止滚动冲突 */
body {
  overflow-x: hidden;
  touch-action: pan-y; /* 仅允许垂直滚动 */
}

#fluid {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  display: block;
}

.scroll-down {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  animation: bounce 2s infinite;
  cursor: pointer;
}

.arrow {
  width: 2rem;
  height: 2rem;
  color: #fff;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  40% {
    transform: translateX(-50%) translateY(-20px);
  }
  60% {
    transform: translateX(-50%) translateY(-10px);
  }
}