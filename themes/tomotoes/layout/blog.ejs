<%
const blogPosts = site.posts.sort('date', -1).toArray();
const excerptLimit = theme.excerpt_length || 175;
const latestPosts = blogPosts.slice(0, 6);
const toneClasses = ['tone-a', 'tone-b', 'tone-c', 'tone-d'];
const coverVideoExts = ['mp4', 'webm', 'ogg', 'mov', 'm4v'];
const resolveCover = function(post) {
    const coverPath = post.cover || post.banner || post.poster;
    if (!coverPath) {
        return null;
    }
    const normalizedPath = String(coverPath).trim();
    const cleanPath = normalizedPath.split('?')[0].split('#')[0];
    const extMatch = cleanPath.match(/\.([^.\/]+)$/);
    const ext = extMatch ? extMatch[1].toLowerCase() : '';
    let type = String(post.cover_type || '').toLowerCase();
    if (!type) {
        type = coverVideoExts.indexOf(ext) > -1 ? 'video' : 'image';
    }
    if (type === 'gif') {
        type = 'image';
    }
    return {
        type: type,
        url: url_for(normalizedPath),
        alt: post.cover_alt || post.title || 'post cover',
        poster: post.cover_poster ? url_for(post.cover_poster) : ''
    };
};
const formatWordCount = function(total) {
    if (total >= 1000) {
        return (total / 1000).toFixed(1).replace(/\.0$/, '') + 'k 字';
    }
    return total + ' 字';
};
%>
<%- partial('_partial/header', {
    title: config.author || config.title || 'Blog',
    hdClass: 'index-header blog-home-header'
}) %>
<div class="container body-wrap blog-home">
    <aside class="blog-home-rail fade" aria-label="博客快捷入口">
        <button type="button" class="blog-home-rail-control" data-rail-action="refresh">刷新</button>
        <button
            type="button"
            class="blog-home-rail-control"
            data-rail-action="latest"
            aria-haspopup="dialog"
            aria-expanded="false"
            aria-controls="latest-posts-popover"
        >
            最新
        </button>
        <a class="blog-home-rail-link" href="<%- url_for('/tags/') %>">标签</a>
        <a class="blog-home-rail-link" href="<%- url_for('/archives/') %>">归档</a>
    </aside>
    <div class="latest-posts-popover" id="latest-posts-popover" aria-hidden="true">
        <div class="latest-posts-popover-card" role="dialog" aria-label="最新博客文章">
            <div class="latest-posts-popover-head">
                <div>
                    <strong>最新文章</strong>
                    <span>按发布时间倒序展示</span>
                </div>
                <button type="button" class="latest-posts-close" data-latest-close aria-label="关闭最新文章面板">
                    <i class="icon icon-close"></i>
                </button>
            </div>
            <% if (latestPosts.length) { %>
            <ol class="latest-posts-list">
                <% latestPosts.forEach(function(post){ %>
                <li class="latest-posts-item">
                    <a class="latest-posts-link" href="<%- url_for(post.path) %>">
                        <time datetime="<%= post.date.toISOString() %>"><%= date(post.date, 'MM-DD') %></time>
                        <span><%- post.title %></span>
                    </a>
                </li>
                <% }) %>
            </ol>
            <% } else { %>
            <p class="latest-posts-empty">这里还没有可以展示的文章。</p>
            <% } %>
        </div>
    </div>
    <section class="blog-home-summary fade" id="blog-top">
        <div>
            <small>Blog Index</small>
            <h2>沿着时间往下翻，就是这段时间留下来的思考与记录。</h2>
        </div>
        <div class="post-count-custom">目前共收录 <%= blogPosts.length %> 篇文章</div>
    </section>
    <ul class="post-list rich-post-list" id="post-list-start">
    <% blogPosts.forEach(function(post, index){ %>
        <%
            const excerptSource = strip_html(post.excerpt || post.content || '').replace(/\s+/g, ' ').trim();
            const excerpt = truncate(excerptSource || '这是一篇新的文章，后续会继续补充更完整的内容。', {
                length: excerptLimit
            });
            const contentSource = strip_html(post.content || '').replace(/\s+/g, '');
            const wordCount = contentSource.length || excerptSource.replace(/\s+/g, '').length || 1;
            const readMinutes = Math.max(1, Math.ceil(wordCount / 420));
            const toneClass = toneClasses[index % toneClasses.length];
            const cover = resolveCover(post);
        %>
        <li class="post-list-item fade">
            <article class="article-card article-type-post author-post-card <%= toneClass %>" itemprop="blogPost">
                <div class="post-cover" aria-hidden="true">
                    <% if (cover) { %>
                        <% if (cover.type === 'video') { %>
                            <video
                                class="post-cover-media post-cover-video"
                                src="<%- cover.url %>"
                                <% if (cover.poster) { %>poster="<%- cover.poster %>"<% } %>
                                autoplay
                                muted
                                loop
                                playsinline
                                webkit-playsinline="true"
                                preload="metadata"
                                disablepictureinpicture
                            ></video>
                        <% } else { %>
                            <img
                                class="post-cover-media"
                                src="<%- cover.url %>"
                                alt="<%- cover.alt %>"
                                loading="lazy"
                                decoding="async"
                            >
                        <% } %>
                    <% } else { %>
                        <canvas class="canvas-cover" data-post-id="<%= post.slug %>" data-tone="<%= toneClass %>"></canvas>
                    <% } %>
                </div>
                <h3 class="post-title">
                    <a href="<%- url_for(post.path) %>" class="post-title-link"><%- post.title %></a>
                </h3>
                <div class="post-meta">
                    <div class="post-meta-info">
                        <span><i class="icon icon-calendar"></i><%= date(post.date, 'YYYY-MM-DD') %></span>
                        <span><i class="icon icon-clock-o"></i><%= readMinutes %> 分钟阅读</span>
                        <span><i class="icon icon-file-text-o"></i><%= formatWordCount(wordCount) %></span>
                    </div>
                </div>
                <div class="post-content">
                    <p><%= excerpt %></p>
                    <div class="post-more-wrapper">
                        <a href="<%- url_for(post.path) %>" class="post-more">阅读全文 <span>»</span></a>
                    </div>
                </div>
                <% if(post.tags && post.tags.length){ %>
                <div class="post-footer">
                    <ul class="article-tag-list">
                        <% post.tags.each(function(tag){ %>
                            <li class="article-tag-list-item">
                                <a class="article-tag-list-link" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
                            </li>
                        <% }) %>
                    </ul>
                </div>
                <% } %>
            </article>
        </li>
    <% }) %>
    </ul>
</div>
