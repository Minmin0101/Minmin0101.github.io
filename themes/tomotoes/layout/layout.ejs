<%
const isPortal = page.layout === 'portal' || is_home();
const bodyClasses = [];
const rewardEnabled = 'reward' in page ? (theme.reward && page.reward) : theme.reward;
const showRewardModal =
    !isPortal &&
    rewardEnabled &&
    (is_post() || page.layout === 'page');
if (isPortal) bodyClasses.push('portal-page');
if (!isPortal) bodyClasses.push('blog-shell');
if (page.layout === 'blog') bodyClasses.push('blog-home-page');
if (is_post()) bodyClasses.push('post-detail-page');
%>
<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<%- partial('_partial/head') %>
<body class="<%= bodyClasses.join(' ') %>">
    <% if (!isPortal) { %>
        <%- partial('_partial/loading') %>
        <%- partial('_partial/menu') %>
    <% } %>
    <main id="main" class="<%= isPortal ? 'portal-main' : '' %>">
        <%- body %>
        <% if (!isPortal) { %>
            <%- partial('_partial/footer') %>
        <% } %>
    </main>
    <% if (showRewardModal) { %>
        <%- partial('_partial/post/reward') %>
    <% } %>
    <% if (!isPortal) { %>
        <%- partial('_partial/after-footer') %>
        <%- partial('_partial/script') %>
    <% } %>
</body>
</html>
