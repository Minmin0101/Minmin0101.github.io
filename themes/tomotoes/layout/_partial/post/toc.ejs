<% if(theme.toc){ 
    var topic = toc(post.content, {
            class: 'post-toc',
            list_number: theme.toc.list_number
        })
    if(topic) {
    %>
    <aside class="post-widget">
        <nav class="post-toc-wrap fade" id="post-toc">
            <%- toc(post.content, {
                class: 'post-toc',
                list_number: theme.toc.list_number
            }) %>
        </nav>
    </aside>
   <% }
} %>
