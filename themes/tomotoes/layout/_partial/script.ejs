<script src="<%- url_for('/vendor/waves/waves.min.js') %>?v=<%= theme_version() %>"></script>

<script>
var BLOG = {
    ROOT: '<%= config.root %>',
    SHARE: <%- theme.share %>,
    REWARD: <%- Boolean(page.reward) %>
};
</script>

<script src="<%- url_for(theme_js('/js/jquery', cache)) %>"></script>

<%- partial('search') %>

<script src="<%- url_for(theme_js('/js/main', cache)) %>"></script>
<script src="<%- url_for(theme_js('/js/script', cache)) %>"></script>

<%- partial('switch') %>

<script src="<%- url_for('/vendor/opencc/full.js') %>?v=<%= theme_version() %>"></script>
<% if (is_post()) { %>
<script src="<%- url_for('/vendor/katex/katex.min.js') %>?v=<%= theme_version() %>"></script>
<script src="<%- url_for('/vendor/katex/contrib/mhchem.min.js') %>?v=<%= theme_version() %>"></script>
<script src="<%- url_for('/vendor/katex/contrib/auto-render.min.js') %>?v=<%= theme_version() %>"></script>
<% } %>
<script src="<%- url_for('/js/blog-enhance.js?v=' + theme_version()) %>"></script>

<% if (page.layout === 'gallery') { %>
<script src="<%- url_for('/js/gallery-viewer.js?v=' + theme_version()) %>"></script>
<% } %>

<% if (page.layout === 'tags') { %>
<script src="<%- url_for('/js/tags-gravity.js?v=' + theme_version()) %>"></script>
<% } %>

<% if (theme.visit_counter) { %>
<script async src="<%- url_for('/vendor/busuanzi/busuanzi.pure.mini.js') %>?v=<%= theme_version() %>"></script>
<% } %>

<%- partial('_partial/live2d-loader') %>
